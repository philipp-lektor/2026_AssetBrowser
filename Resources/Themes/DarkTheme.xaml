<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System.Windows;assembly=PresentationFramework">
    <SolidColorBrush x:Key="Brush.WindowBackground" Color="#FF0F172A" />
    <SolidColorBrush x:Key="Brush.PanelBackground" Color="#FF111827" />
    <SolidColorBrush x:Key="Brush.PanelBorder" Color="#FF334155" />
    <SolidColorBrush x:Key="Brush.SubtlePanelBackground" Color="#FF1E293B" />
    <SolidColorBrush x:Key="Brush.ItemBackground" Color="#FF172033" />
    <SolidColorBrush x:Key="Brush.ItemBorder" Color="#FF334155" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FFF9FAFB" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="#FF94A3B8" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FFCBD5E1" />
    <SolidColorBrush x:Key="Brush.ControlBackground" Color="#FF0F172A" />
    <SolidColorBrush x:Key="Brush.ControlForeground" Color="#FFF9FAFB" />
    <SolidColorBrush x:Key="Brush.ControlBorder" Color="#FF475569" />
    <SolidColorBrush x:Key="Brush.ControlHoverBackground" Color="#FF1E293B" />
    <SolidColorBrush x:Key="Brush.ControlSelectionBackground" Color="#FF334155" />
    <SolidColorBrush x:Key="Brush.DropDownBackground" Color="#FF0F172A" />
    <SolidColorBrush x:Key="Brush.DropDownForeground" Color="#FFF9FAFB" />
    <SolidColorBrush x:Key="Brush.ButtonBackground" Color="#FF1E293B" />
    <SolidColorBrush x:Key="Brush.ButtonForeground" Color="#FFF9FAFB" />
    <SolidColorBrush x:Key="Brush.ButtonBorder" Color="#FF475569" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.WindowBrushKey}" Color="#FF0F172A" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.WindowTextBrushKey}" Color="#FFF9FAFB" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.ControlBrushKey}" Color="#FF1E293B" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.ControlTextBrushKey}" Color="#FFF9FAFB" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.HighlightBrushKey}" Color="#FF334155" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.HighlightTextBrushKey}" Color="#FFF9FAFB" />
    <SolidColorBrush x:Key="Brush.TypeBadgeBackground" Color="#FF312E81" />
    <SolidColorBrush x:Key="Brush.TypeBadgeForeground" Color="#FFC7D2FE" />
    <SolidColorBrush x:Key="Brush.SuccessBackground" Color="#FF14532D" />
    <SolidColorBrush x:Key="Brush.SuccessForeground" Color="#FFBBF7D0" />
    <SolidColorBrush x:Key="Brush.WarningBackground" Color="#FF7F1D1D" />
    <SolidColorBrush x:Key="Brush.WarningForeground" Color="#FFFECACA" />
</ResourceDictionary>
