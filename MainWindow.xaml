<Window x:Class="AssetBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AssetBrowser" Height="600" Width="1000"
        MinHeight="500" MinWidth="900">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                Margin="0,0,0,16"
                Background="#FFF3F4F6"
                BorderBrush="#FFD0D7DE"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="AssetBrowser"
                           FontSize="24"
                           FontWeight="Bold" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#FF4B5563"
                           Text="Simple learning project for WPF, MVVM, data binding and commands." />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,16">
            <Button Content="Add Asset"
                    Width="120"
                    Padding="12,6"
                    Margin="0,0,8,0"
                    Command="{Binding AddAssetCommand}" />
            <Button Content="Delete Selected Asset"
                    Width="170"
                    Padding="12,6"
                    Margin="0,0,8,0"
                    Command="{Binding DeleteSelectedAssetCommand}" />
            <Button Content="Clear Selection"
                    Width="130"
                    Padding="12,6"
                    Command="{Binding ClearSelectionCommand}" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="12"
                    Background="White"
                    BorderBrush="#FFD0D7DE"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Assets"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12" />

                    <Grid Grid.Row="1"
                          Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Padding="8,6"
                                 Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding AssetTypeFilters}"
                                  SelectedItem="{Binding SelectedAssetTypeFilter, Mode=TwoWay}"
                                  Padding="6,4" />

                        <ComboBox Grid.Column="4"
                                  ItemsSource="{Binding ApprovalFilters}"
                                  SelectedItem="{Binding SelectedApprovalFilter, Mode=TwoWay}"
                                  Padding="6,4" />
                    </Grid>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding FilteredAssets}"
                             SelectedItem="{Binding SelectedAsset, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10"
                                        Margin="0,0,0,8"
                                        BorderBrush="#FFE5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="#FF6B7280"
                                                   Text="{Binding FileName}" />
                                        <TextBlock Margin="0,2,0,0"
                                                   Foreground="#FF6B7280"
                                                   Text="{Binding AssetType}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="16"
                    Background="White"
                    BorderBrush="#FFD0D7DE"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Asset Details"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,12,12"
                                   VerticalAlignment="Center"
                                   Text="Title" />
                        <TextBox Grid.Row="0"
                                 Grid.Column="1"
                                 Margin="0,0,0,12"
                                 Text="{Binding SelectedAsset.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,0,12,12"
                                   VerticalAlignment="Center"
                                   Text="File name" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Margin="0,0,0,12"
                                 Text="{Binding SelectedAsset.FileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,0,12,12"
                                   VerticalAlignment="Center"
                                   Text="Asset type" />
                        <ComboBox Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="0,0,0,12"
                                  ItemsSource="{Binding AssetTypes}"
                                  SelectedItem="{Binding SelectedAsset.AssetType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Margin="0,0,12,12"
                                   VerticalAlignment="Top"
                                   Text="Description" />
                        <TextBox Grid.Row="3"
                                 Grid.Column="1"
                                 Margin="0,0,0,12"
                                 Height="80"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding SelectedAsset.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Margin="0,0,12,12"
                                   VerticalAlignment="Center"
                                   Text="Created by" />
                        <TextBox Grid.Row="4"
                                 Grid.Column="1"
                                 Margin="0,0,0,12"
                                 Text="{Binding SelectedAsset.CreatedBy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="5"
                                   Grid.Column="0"
                                   Margin="0,0,12,12"
                                   VerticalAlignment="Center"
                                   Text="Created at" />
                        <DatePicker Grid.Row="5"
                                    Grid.Column="1"
                                    Margin="0,0,0,12"
                                    SelectedDate="{Binding SelectedAsset.CreatedAt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="6"
                                   Grid.Column="0"
                                   Margin="0,0,12,12"
                                   VerticalAlignment="Center"
                                   Text="Approved" />
                        <CheckBox Grid.Row="6"
                                  Grid.Column="1"
                                  Margin="0,0,0,12"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding SelectedAsset.IsApproved, Mode=TwoWay}" />

                        <TextBlock Grid.Row="7"
                                   Grid.Column="0"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center"
                                   Text="Thumbnail path" />
                        <TextBox Grid.Row="7"
                                 Grid.Column="1"
                                 Text="{Binding SelectedAsset.ThumbnailPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
