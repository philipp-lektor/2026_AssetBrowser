<Window x:Class="AssetBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AssetBrowser" Height="600" Width="1000"
        MinHeight="800" MinWidth="1200">
    <Window.Resources>
        <SolidColorBrush x:Key="Brush.PanelBackground" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="Brush.PanelBorder" Color="#FFD0D7DE" />
        <SolidColorBrush x:Key="Brush.SubtlePanelBackground" Color="#FFF3F4F6" />
        <SolidColorBrush x:Key="Brush.ItemBackground" Color="#FFF9FAFB" />
        <SolidColorBrush x:Key="Brush.ItemBorder" Color="#FFE5E7EB" />
        <SolidColorBrush x:Key="Brush.TextMuted" Color="#FF6B7280" />
        <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FF4B5563" />
        <SolidColorBrush x:Key="Brush.TypeBadgeBackground" Color="#FFE0E7FF" />
        <SolidColorBrush x:Key="Brush.TypeBadgeForeground" Color="#FF3730A3" />
        <SolidColorBrush x:Key="Brush.SuccessBackground" Color="#FFDCFCE7" />
        <SolidColorBrush x:Key="Brush.SuccessForeground" Color="#FF166534" />
        <SolidColorBrush x:Key="Brush.WarningBackground" Color="#FFFEE2E2" />
        <SolidColorBrush x:Key="Brush.WarningForeground" Color="#FF991B1B" />

        <Thickness x:Key="Spacing.FieldMargin">0,0,0,12</Thickness>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="FormLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="{StaticResource Spacing.FieldMargin}" />
        </Style>

        <Style x:Key="FieldComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Margin" Value="{StaticResource Spacing.FieldMargin}" />
        </Style>

        <Style x:Key="FieldDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Margin" Value="{StaticResource Spacing.FieldMargin}" />
        </Style>

        <Style x:Key="FieldCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="{StaticResource Spacing.FieldMargin}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="PreviewPlaceholderTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
        </Style>

        <Style x:Key="PreviewImageStyle" TargetType="Image">
            <Setter Property="Stretch" Value="UniformToFill" />
            <Setter Property="Visibility" Value="Visible" />
        </Style>

        <Style x:Key="ItemMetaTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
        </Style>

        <Style x:Key="ItemStatusBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="12,0,0,0" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{StaticResource Brush.WarningBackground}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsApproved}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.SuccessBackground}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ItemStatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Brush.WarningForeground}" />
            <Setter Property="Text" Value="Not approved" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsApproved}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Brush.SuccessForeground}" />
                    <Setter Property="Text" Value="Approved" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="AssetListItemTemplate">
            <Border Padding="12"
                    Margin="0,0,0,10"
                    Background="{StaticResource Brush.ItemBackground}"
                    BorderBrush="{StaticResource Brush.ItemBorder}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="88" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.RowSpan="4"
                            Grid.Column="0"
                            Height="64"
                            Background="{StaticResource Brush.ItemBorder}"
                            CornerRadius="6"
                            ClipToBounds="True">
                        <Grid>
                            <TextBlock Text="No Preview">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource PreviewPlaceholderTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ThumbnailPath}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ThumbnailPath}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Image Source="{Binding ThumbnailPath}">
                                <Image.Style>
                                    <Style TargetType="Image" BasedOn="{StaticResource PreviewImageStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ThumbnailPath}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ThumbnailPath}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="0"
                          Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Title}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />

                        <Border Grid.Column="1"
                                Padding="8,3"
                                Margin="12,0,0,0"
                                Background="{StaticResource Brush.TypeBadgeBackground}"
                                CornerRadius="12">
                            <TextBlock Text="{Binding AssetType}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TypeBadgeForeground}" />
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               Margin="0,8,0,0"
                               Style="{StaticResource ItemMetaTextStyle}"
                               Text="{Binding FileName}" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Text="{Binding Description}"
                               TextTrimming="CharacterEllipsis" />

                    <DockPanel Grid.Row="3"
                               Grid.Column="2"
                               Margin="0,10,0,0"
                               LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Style="{StaticResource ItemMetaTextStyle}"
                                   Text="{Binding CreatedBy, StringFormat=By {0}}" />

                        <TextBlock DockPanel.Dock="Left"
                                   Margin="12,0,0,0"
                                   Style="{StaticResource ItemMetaTextStyle}"
                                   Text="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy}}" />

                        <Border DockPanel.Dock="Right"
                                Style="{StaticResource ItemStatusBadgeStyle}">
                            <TextBlock Style="{StaticResource ItemStatusTextStyle}" />
                        </Border>
                    </DockPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                Margin="0,0,0,16"
                Background="{StaticResource Brush.SubtlePanelBackground}"
                Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="AssetBrowser"
                           FontSize="24"
                           FontWeight="Bold" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           Text="Simple learning project for WPF, MVVM, data binding and commands." />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,16">
            <Button Style="{StaticResource ActionButtonStyle}"
                    Content="Add Asset"
                    Width="120"
                    Command="{Binding AddAssetCommand}" />
            <Button Style="{StaticResource ActionButtonStyle}"
                    Content="Delete Selected Asset"
                    Width="170"
                    Command="{Binding DeleteSelectedAssetCommand}" />
            <Button Style="{StaticResource ActionButtonStyle}"
                    Content="Clear Selection"
                    Width="130"
                    Margin="0"
                    Command="{Binding ClearSelectionCommand}" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="12"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Assets"
                               Style="{StaticResource SectionTitleTextStyle}" />

                    <Grid Grid.Row="1"
                          Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Padding="8,6"
                                 Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding AssetTypeFilters}"
                                  SelectedItem="{Binding SelectedAssetTypeFilter, Mode=TwoWay}"
                                  Padding="6,4" />

                        <ComboBox Grid.Column="4"
                                  ItemsSource="{Binding ApprovalFilters}"
                                  SelectedItem="{Binding SelectedApprovalFilter, Mode=TwoWay}"
                                  Padding="6,4" />
                    </Grid>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding FilteredAssets}"
                             SelectedItem="{Binding SelectedAsset, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemTemplate="{StaticResource AssetListItemTemplate}" />
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="16"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Asset Details"
                               Style="{StaticResource SectionTitleTextStyle}"
                               Margin="0,0,0,16" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Style="{StaticResource FormLabelTextStyle}"
                                   VerticalAlignment="Top"
                                   Text="Thumbnail" />
                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Height="140"
                                Margin="0,0,0,12"
                                Background="{StaticResource Brush.SubtlePanelBackground}"
                                Style="{StaticResource CardBorderStyle}"
                                ClipToBounds="True">
                            <Grid>
                                <TextBlock Text="No preview available">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PreviewPlaceholderTextStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedAsset.ThumbnailPath}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedAsset.ThumbnailPath}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Image Source="{Binding SelectedAsset.ThumbnailPath}">
                                    <Image.Style>
                                        <Style TargetType="Image" BasedOn="{StaticResource PreviewImageStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedAsset.ThumbnailPath}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedAsset.ThumbnailPath}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </Grid>
                        </Border>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Style="{StaticResource FormLabelTextStyle}"
                                   Text="Title" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Style="{StaticResource FieldTextBoxStyle}"
                                 Text="{Binding SelectedAsset.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Style="{StaticResource FormLabelTextStyle}"
                                   Text="File name" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Style="{StaticResource FieldTextBoxStyle}"
                                 Text="{Binding SelectedAsset.FileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Style="{StaticResource FormLabelTextStyle}"
                                   Text="Asset type" />
                        <ComboBox Grid.Row="3"
                                  Grid.Column="1"
                                  Style="{StaticResource FieldComboBoxStyle}"
                                  ItemsSource="{Binding AssetTypes}"
                                  SelectedItem="{Binding SelectedAsset.AssetType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Style="{StaticResource FormLabelTextStyle}"
                                   VerticalAlignment="Top"
                                   Text="Description" />
                        <TextBox Grid.Row="4"
                                 Grid.Column="1"
                                  Style="{StaticResource FieldTextBoxStyle}"
                                 Height="80"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding SelectedAsset.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="5"
                                   Grid.Column="0"
                                   Style="{StaticResource FormLabelTextStyle}"
                                   Text="Created by" />
                        <TextBox Grid.Row="5"
                                 Grid.Column="1"
                                 Style="{StaticResource FieldTextBoxStyle}"
                                 Text="{Binding SelectedAsset.CreatedBy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="6"
                                   Grid.Column="0"
                                   Style="{StaticResource FormLabelTextStyle}"
                                   Text="Created at" />
                        <DatePicker Grid.Row="6"
                                    Grid.Column="1"
                                    Style="{StaticResource FieldDatePickerStyle}"
                                    SelectedDate="{Binding SelectedAsset.CreatedAt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="7"
                                   Grid.Column="0"
                                   Style="{StaticResource FormLabelTextStyle}"
                                   Text="Approved" />
                        <CheckBox Grid.Row="7"
                                  Grid.Column="1"
                                  Style="{StaticResource FieldCheckBoxStyle}"
                                  IsChecked="{Binding SelectedAsset.IsApproved, Mode=TwoWay}" />

                        <TextBlock Grid.Row="8"
                                   Grid.Column="0"
                                   Style="{StaticResource FormLabelTextStyle}"
                                   Margin="0,0,12,0"
                                   Text="Thumbnail path" />
                        <TextBox Grid.Row="8"
                                 Grid.Column="1"
                                 Style="{StaticResource FieldTextBoxStyle}"
                                 Margin="0"
                                 Text="{Binding SelectedAsset.ThumbnailPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
